# 🔴 NARUTO Environment Configuration - EXAMPLE
# Copy this file to .env and fill in your actual values
# .env file will be ignored by git and not pushed to GitHub

# ═══════════════════════════════════════════════════════
# Ollama Configuration (Remote Server on Windows/Mac)
# ═══════════════════════════════════════════════════════

# Ollama server URL (replace with your machine's IP)
# Examples:
#   - Local: http://localhost:11434
#   - Windows: http://192.168.56.1:11434
#   - Mac: http://192.168.1.100:11434
#   - Remote Server: http://192.168.x.x:11434
OLLAMA_URL=http://YOUR_MACHINE_IP:11434

# Optional: API key if Ollama requires authentication
OLLAMA_API_KEY=

# ═══════════════════════════════════════════════════════
# Flask Configuration
# ═══════════════════════════════════════════════════════

FLASK_ENV=production
FLASK_DEBUG=False

# ═══════════════════════════════════════════════════════
# Additional Security Settings (Optional)
# ═══════════════════════════════════════════════════════

# Flask Secret Key (generate one with: python3 -c "import secrets; print(secrets.token_hex(32))")
# FLASK_SECRET_KEY=your-secret-key-here

# ═══════════════════════════════════════════════════════
# SETUP INSTRUCTIONS:
# ═══════════════════════════════════════════════════════
#
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and replace YOUR_MACHINE_IP with your actual IP
# 3. The .env file is NEVER committed to GitHub (see .gitignore)
# 4. Share .env.example instead (without sensitive data)
#
# FINDING YOUR IP ADDRESS:
# 
# Windows:
#   - Open Command Prompt
#   - Type: ipconfig
#   - Look for "IPv4 Address" under your network adapter
#   - Example: 192.168.56.1
#
# Mac/Linux:
#   - Open Terminal
#   - Type: hostname -I
#   - Copy the first IP address
#   - Example: 192.168.1.100
#
# ═══════════════════════════════════════════════════════
